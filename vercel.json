{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/auth/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "crons": [
    {
      "path": "/api/cron/followups",
      "schedule": "0 * * * *"
    }
  ]
}
